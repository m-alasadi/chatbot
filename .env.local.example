# =============================================================================
# ALKAFEEL CHATBOT — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Only variables actually used by the application are listed here.
# =============================================================================

# --- Required: OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Required: Site REST API ---
SITE_API_BASE_URL=
SITE_API_TOKEN=

# --- Optional: Future Phase B infrastructure ---
# Uncomment and configure when implementing Phase B features.
# VERCEL_KV_REST_API_URL=
# VERCEL_KV_REST_API_TOKEN=
